{
  "mcpServers": {
    "memory": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-memory"
      ]
    },
    "osascript": {
      "command": "node",
      "args": [
        "/Users/wsig/.mcp-fixed-servers/fixed-osascript.js"
      ]
    },
    "clipboard": {
      "command": "node",
      "args": [
        "/Users/wsig/.mcp-fixed-servers/fixed-clipboard.js"
      ]
    },
    "notifications": {
      "command": "node",
      "args": [
        "/Users/wsig/.mcp-fixed-servers/fixed-notifications.js"
      ]
    },
    "xcode": {
      "command": "node",
      "args": [
        "/Users/wsig/.mcp-fixed-servers/fixed-xcode.js"
      ]
    },
    "calendar": {
      "command": "node",
      "args": [
        "/Users/wsig/.mcp-fixed-servers/fixed-calendar.js"
      ]
    },
    "filesystem": {
      "command": "/Users/wsig/.local/share/mcp/node_modules/.bin/mcp-server-filesystem",
      "args": [
        "/Users/wsig"
      ]
    },
    "github": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ]
    },
    "mcp-server-fetch": {
      "command": "/Users/wsig/.local/bin/uvx",
      "args": [
        "mcp-server-fetch"
      ]
    },
    "puppeteer": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-puppeteer"
      ]
    },
    "mcp-server-sequential-thinking": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-server-sequential-thinking"
      ]
    },
    "mcp-server-sqlite": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-server-sqlite"
      ]
    },
    "shell": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-shell"
      ]
    },
    "mcp-server-docker": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-server-docker"
      ],
      "disabled": true
    },
    "microsoft_playwright_mcp": {
      "command": "npx",
      "args": [
        "@playwright/mcp@latest"
      ]
    },
    "postmanlabs_postman_mcp_server": {
      "command": "npx",
      "args": [
        "@postman/postman-mcp-server@latest"
      ],
      "env": {
        "POSTMAN_API_KEY": "${input:api_key}"
      },
      "disabled": true
    },
    "vercel": {
      "url": "https://mcp.vercel.com"
    },
    "supabase": {
      "command": "npx",
      "args": ["-y", "@supabase/mcp-server-supabase@latest", "--access-token", "REDACTED"]
    }
  }
}
