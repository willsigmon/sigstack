{
  "name": "sigskills",
  "version": "0.1.0",
  "description": "Hybrid local/cloud MCP server for semantic skill search, generation, and sync across Claude Code and Codex CLI",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "sigskills": "dist/index.js"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && node scripts/copy-db-assets.mjs && chmod +x dist/index.js",
    "start": "node dist/index.js",
    "test": "vitest",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "db:migrate": "node -e \"require('./dist/db/migrations.js').runMigrations()\"",
    "index:local": "node dist/cli.js index --source local",
    "index:all": "node dist/cli.js index --source all"
  },
  "keywords": [
    "mcp",
    "claude",
    "codex",
    "skills",
    "ai",
    "semantic-search",
    "code-generation"
  ],
  "author": "wsig",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@modelcontextprotocol/sdk": "^1.0.4",
    "@octokit/rest": "^21.0.2",
    "better-sqlite3": "^11.8.0",
    "chokidar": "^4.0.3",
    "dotenv": "^16.4.7",
    "gray-matter": "^4.0.3",
    "hono": "^4.6.14",
    "openai": "^4.77.3",
    "yaml": "^2.6.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.2",
    "@typescript-eslint/eslint-plugin": "^8.18.1",
    "@typescript-eslint/parser": "^8.18.1",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
